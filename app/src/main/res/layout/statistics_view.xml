<?xml version="1.0" encoding="utf-8"?>
<merge
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical">

        <TextView
            android:id="@+id/tv_main_stats_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/base_title_text_style"
            android:text="@string/statistics_active_tasks_title"
            android:layout_marginTop="@dimen/margin_32"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tv_main_stats"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/base_title_text_style"
            tools:text="3"
            android:layout_marginStart="@dimen/margin_8"
            android:layout_marginTop="@dimen/margin_32"
            app:layout_constraintHorizontal_bias="0"
            app:layout_constraintStart_toEndOf="@id/tv_main_stats_title"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tv_high_priority_stats_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/base_body_text_style"
            tools:text="High Priority Stats: "
            app:layout_constraintTop_toBottomOf="@id/tv_main_stats_title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tv_high_priority_stats"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/base_body_text_style"
            tools:text="10"
            android:layout_marginStart="@dimen/margin_8"
            app:layout_constraintHorizontal_bias="0"
            app:layout_constraintStart_toEndOf="@id/tv_high_priority_stats_title"
            app:layout_constraintTop_toBottomOf="@id/tv_main_stats_title"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tv_medium_priority_stats_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/base_body_text_style"
            tools:text="Medium Priority:"
            app:layout_constraintTop_toBottomOf="@id/tv_high_priority_stats_title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tv_medium_priority_stats"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/base_body_text_style"
            tools:text="10"
            android:layout_marginStart="@dimen/margin_8"
            app:layout_constraintHorizontal_bias="0"
            app:layout_constraintStart_toEndOf="@id/tv_medium_priority_stats_title"
            app:layout_constraintTop_toBottomOf="@id/tv_high_priority_stats_title"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tv_low_priority_stats_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/base_body_text_style"
            tools:text="Low Priority:"
            app:layout_constraintTop_toBottomOf="@id/tv_medium_priority_stats_title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tv_low_priority_stats"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/base_body_text_style"
            tools:text="10"
            android:layout_marginStart="@dimen/margin_8"
            app:layout_constraintHorizontal_bias="0"
            app:layout_constraintStart_toEndOf="@id/tv_low_priority_stats_title"
            app:layout_constraintTop_toBottomOf="@id/tv_medium_priority_stats_title"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</merge>